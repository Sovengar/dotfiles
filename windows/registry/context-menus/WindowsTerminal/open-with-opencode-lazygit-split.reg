Windows Registry Editor Version 5.00

; Añadir opción "Abrir con OpenCode + LazyGit" al clic derecho en carpetas
[HKEY_CLASSES_ROOT\Directory\shell\OpenWithOpenCodeLazygit]
@="Abrir con OpenCode + LazyGit"
"Icon"="cmd.exe"

[HKEY_CLASSES_ROOT\Directory\shell\OpenWithOpenCodeLazygit\command]
@="wt.exe new-tab --title \"OpenCode\" -- \"C:\\nvm4w\\nodejs\\node.exe\" \"C:\\nvm4w\\nodejs\\node_modules\\opencode-ai\\bin\\opencode\" \"%1\" ; split-pane -V -- \"C:\\Users\\buble\\AppData\\Local\\Microsoft\\WinGet\\Packages\\JesseDuffield.lazygit_Microsoft.Winget.Source_8wekyb3d8bbwe\\lazygit.exe\" -p \"%1\""

; También funciona para carpetas en el escritorio (Directory\Background)
[HKEY_CLASSES_ROOT\Directory\Background\shell\OpenWithOpenCodeLazygit]
@="Abrir con OpenCode + LazyGit"
"Icon"="cmd.exe"

[HKEY_CLASSES_ROOT\Directory\Background\shell\OpenWithOpenCodeLazygit\command]
@="wt.exe new-tab --title \"OpenCode\" -- \"C:\\nvm4w\\nodejs\\node.exe\" \"C:\\nvm4w\\nodejs\\node_modules\\opencode-ai\\bin\\opencode\" \"%V\" ; split-pane -V -- \"C:\\Users\\buble\\AppData\\Local\\Microsoft\\WinGet\\Packages\\JesseDuffield.lazygit_Microsoft.Winget.Source_8wekyb3d8bbwe\\lazygit.exe\" -p \"%V\""
