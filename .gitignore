# .gitignore for chezmoi repo root (not dotfiles themselves)

# NEVER commit these
env.toml
*.env
.env.local
*.log

# chezmoi internal
.chezmoi.local.toml
.chezmoi.cache/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Node/JS artifacts (auxiliary files)
package-lock.json
node_modules/

# Auxiliary directories that are NOT dotfiles
logs/
