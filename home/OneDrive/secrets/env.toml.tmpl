# ============================================
# env.toml — Secretos personales
# ============================================
# Copia este archivo como env.toml en OneDrive\secrets\
# y rellena tus valores.
# 
# chezmoi.toml.tmpl lo lee para poblar [data]:
#   {{ .email }}
#   {{ .ssh_host }}
#   {{ .ssh_username }}
#   {{ .ssh_identity }}
#
# firecrawl-key.ps1 busca firecrawl = "fc-..."
# ============================================

[git]
email = "tu-email@example.com"

[ssh]
host = "192.168.1.1"
username = "tu-usuario"
identity = "tu-clave"

firecrawl = "fc-tu-api-key"

[opencode]
config = '''
{
  "openrouter": {"type": "api", "key": "sk-or-v1-tu-api-key"},
  "google": {"type": "api", "key": "AIza-tu-api-key"},
  "opencode": {"type": "api", "key": "sk-tu-api-key"},
  "opencode-go": {"type": "api", "key": "sk-tu-api-key"},
  "github-copilot": {"type": "oauth", "refresh": "gho_...", "access": "gho_...", "expires": 0},
  "openai": {"type": "oauth", "refresh": "rt_...", "access": "eyJ...", "expires": 1777225245517, "accountId": "..."}
}
'''
# ^ Pega aqui el contenido COMPLETO de tu auth.json real
#   (el que ves con: cat $env:LOCALAPPDATA\..\Local\share\opencode\auth.json)
#   Entre comillas triples simples (''') para que TOML lo trate como string literal.
#   Formato: JSON valido, sin comentarios internos, sin trailing commas.
#   NOTA: Las ''' deben estar solas en su linea (la de apertura y cierre).
#         El JSON interno usa " (doble comilla), que dentro de ''' es literal.
