#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
export PATH="$script_dir:$PATH"

mode_values=(theme wallbash_auto wallbash_dark wallbash_light)
mode_icons=(󰔎 󰖨 󰖔 󰖙)
mode_labels=(theme auto dark light)

notify_waybar() {
    pkill -RTMIN+9 waybar 2>/dev/null || true
}

detach_from_waybar() {
    [[ ${WAYBAR_WALLBASH_MODE_DETACHED:-0} == 1 ]] && return 0

    if systemd-run --user --collect --quiet \
        --setenv=WAYBAR_WALLBASH_MODE_DETACHED=1 \
        --setenv=DISPLAY="${DISPLAY:-}" \
        --setenv=WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-}" \
        --setenv=XDG_CURRENT_DESKTOP="${XDG_CURRENT_DESKTOP:-}" \
        --setenv=XDG_SESSION_DESKTOP="${XDG_SESSION_DESKTOP:-}" \
        --setenv=HYPRLAND_INSTANCE_SIGNATURE="${HYPRLAND_INSTANCE_SIGNATURE:-}" \
        -- "$0" "$@" 2>/dev/null; then
        exit 0
    fi

    ( sleep 0.2; WAYBAR_WALLBASH_MODE_DETACHED=1 "$0" "$@" ) & disown
    exit 0
}

current_index() {
    local mode
    mode=$(awk -F= '$1 == "PALETTE_SOURCE" { gsub(/"/, "", $2); print $2 }' \
        "${HYDE_STATE_FILE:-$HOME/.local/state/hypr/hyde.conf}" 2>/dev/null)
    mode="${mode:-theme}"

    for i in "${!mode_values[@]}"; do
        if [[ ${mode_values[$i]} == "$mode" ]]; then
            printf '%s' "$i"
            return
        fi
    done

    printf '%s' 0
}

set_mode() {
    local index=$1
    [[ $index =~ ^[0-3]$ ]] || exit 1

    eval "$(hyde-shell init)" || true
    set_conf "PALETTE_SOURCE" "${mode_values[$index]}"
    "$LIB_DIR/hyde/theme.switch.sh"
    notify-send -a "HyDE" "Palette switcher" "${mode_labels[$index]}"
    notify_waybar
}

next_mode() {
    local index
    index=$(current_index)
    set_mode "$(((index + 1) % ${#mode_values[@]}))"
}

menu_mode() {
    local selection index
    local color_override='* { main-bg: #04020BF2; select-bg: #CFAAF0D9; }'

    selection=$(printf '%s\n' \
        "0  ${mode_icons[0]}  theme  - static theme colors" \
        "1  ${mode_icons[1]}  auto   - wallpaper colors" \
        "2  ${mode_icons[2]}  dark   - force dark wallpaper colors" \
        "3  ${mode_icons[3]}  light  - force light wallpaper colors" \
        | rofi -dmenu -i -p "Palette" -theme-str "$color_override" -theme "clipboard") || exit 0

    index=${selection%% *}
    set_mode "$index"
}

status_json() {
    local index mode icon tooltip class

    index=$(current_index)
    mode=${mode_labels[$index]}
    icon=${mode_icons[$index]}
    class="wallbash-$mode"
    tooltip="Palette: <b>$mode</b>\nLeft click: next palette source\nRight click: choose palette source\nSources: theme, auto, dark, light"

    jq -cn \
        --arg text "$icon $mode" \
        --arg tooltip "$tooltip" \
        --arg class "$class" \
        '{text: $text, tooltip: $tooltip, class: $class}'
}

case "${1:-}" in
    --next) detach_from_waybar "$@"; next_mode ;;
    --menu) detach_from_waybar "$@"; menu_mode ;;
    --set) detach_from_waybar "$@"; set_mode "${2:-}" ;;
    *) status_json ;;
esac
