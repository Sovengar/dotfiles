#!/usr/bin/env bash

set -euo pipefail

show_all=false

usage() {
  cat <<'EOF'
  __                         __  __
 / _|_   _ _ __  _ __  _   _ \ \/ /
| |_| | | | '_ \| '_ \| | | | >  <
|  _| |_| | | | | | | | |_| |/ /\ \
|_|  \__,_|_| |_|_| |_|\__, /_/  \_\
                       |___/

show-funny-x - lista comandos divertidos/visuales de terminal

Uso:
  show-funny-x        Muestra solo comandos instalados
  show-funny-x --all  Muestra instalados y faltantes
  show-funny-x --help Muestra esta ayuda
EOF
}

print_banner() {
  cat <<'EOF'
  __                         __  __
 / _|_   _ _ __  _ __  _   _ \ \/ /
| |_| | | | '_ \| '_ \| | | | >  <
|  _| |_| | | | | | | | |_| |/ /\ \
|_|  \__,_|_| |_|_| |_|\__, /_/  \_\
                       |___/

Funny & visual terminal command index
EOF

  if [[ "$show_all" == true ]]; then
    printf 'Mode: installed + missing commands\n\n'
  else
    printf 'Mode: installed commands only. Use show-funny-x --all to include missing tools.\n\n'
  fi
}

print_category_header() {
  local category=$1

  printf '\n+------------------------------+----------+------------------------------------------------------------------+\n'
  printf '| %-28s | %-8s | %-64s |\n' "$category" "STATUS" "DESCRIPTION"
  printf '+------------------------------+----------+------------------------------------------------------------------+\n'
}

print_row() {
  local command_name=$1
  local status=$2
  local description=$3

  printf '| %-28s | %-8s | %-64s |\n' "$command_name" "$status" "$description"
}

print_category_footer() {
  printf '+------------------------------+----------+------------------------------------------------------------------+\n'
}

case "${1:-}" in
  "") ;;
  --all | -a) show_all=true ;;
  --help | -h)
    usage
    exit 0
    ;;
  *)
    printf 'Uso invalido: %s\n\n' "$1" >&2
    usage >&2
    exit 2
    ;;
esac

tools=(
  "Favoritos|hollywood|Simula una terminal hacker absurda."
  "Favoritos|asciiquarium|Acuario animado en ASCII."
  "Favoritos|pipes.sh|Animacion de tuberias tipo screensaver."
  "Favoritos|cmatrix|Lluvia estilo Matrix en ASCII."
  "Favoritos|cava|Visualizador de audio en terminal."
  "Visualizadores|cbonsai|Bonsai procedural en ASCII/ANSI."
  "Visualizadores|nyancat|Animacion Nyan Cat en terminal."
  "ASCII y banners|fastfetch|Resumen del sistema con logo/arte ASCII."
  "Texto divertido|figlet|Necesita texto: figlet hola."
  "Texto divertido|toilet|Necesita texto: toilet hola."
  "Texto divertido|lolcat|Filtro de color: fortune | lolcat."
  "Texto divertido|cowsay|Necesita texto: cowsay hola."
  "Texto divertido|cowthink|Necesita texto: cowthink hola."
  "Humor|sl|Tren de vapor cuando escribes mal ls."
  "Humor|pokego|Sprites de Pokemon en terminal."
  "Humor|fortune|Frases, citas y chistes aleatorios."
  "Humor|ponysay|Version pony de cowsay."
  "Caos controlado|aafire|Fuego ASCII desde aalib."
)

print_banner

found=0
current_category=""
category_has_rows=false

for entry in "${tools[@]}"; do
  category=${entry%%|*}
  rest=${entry#*|}
  command_name=${rest%%|*}
  description=${rest#*|}

  if [[ "$category" != "$current_category" ]]; then
    if [[ -n "$current_category" && "$category_has_rows" == true ]]; then
      print_category_footer
    fi

    current_category=$category
    category_has_rows=false
  fi

  if command -v "$command_name" >/dev/null 2>&1; then
    if [[ "$category_has_rows" == false ]]; then
      print_category_header "$category"
      category_has_rows=true
    fi

    print_row "$command_name" "ok" "$description"
    found=$((found + 1))
  elif [[ "$show_all" == true ]]; then
    if [[ "$category_has_rows" == false ]]; then
      print_category_header "$category"
      category_has_rows=true
    fi

    print_row "$command_name" "missing" "$description"
  fi
done

if [[ "$category_has_rows" == true ]]; then
  print_category_footer
fi

if (( found == 0 )); then
  printf '\nNo encontre ninguna herramienta de la lista en PATH. Usa show-funny-x --all para ver la lista completa.\n' >&2
  exit 1
fi
