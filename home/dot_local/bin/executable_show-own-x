#!/usr/bin/env bash

set -euo pipefail

show_all=false

usage() {
  cat <<'EOF'
                         __  __
  ___ __      ___ __     \ \/ /
 / _ \\ \ /\ / / '_ \____ >  <
| (_) |\ V  V /| | | |___/ /\ \
 \___/  \_/\_/ |_| |_|  /_/  \_\

show-own-x - lista comandos propios creados/customizados por mi

Uso:
  show-own-x        Muestra solo comandos disponibles
  show-own-x --all  Muestra disponibles y faltantes
  show-own-x --help Muestra esta ayuda
EOF
}

print_banner() {
  cat <<'EOF'
                         __  __
  ___ __      ___ __     \ \/ /
 / _ \\ \ /\ / / '_ \____ >  <
| (_) |\ V  V /| | | |___/ /\ \
 \___/  \_/\_/ |_| |_|  /_/  \_\

Own command index
EOF

  if [[ "$show_all" == true ]]; then
    printf 'Mode: available + missing commands\n\n'
  else
    printf 'Mode: available commands only. Use show-own-x --all to include missing tools.\n\n'
  fi
}

print_header() {
  printf '+------------------------------+----------+------------------------------------------------------------------+\n'
  printf '| %-28s | %-8s | %-64s |\n' "COMMAND" "STATUS" "DESCRIPTION"
  printf '+------------------------------+----------+------------------------------------------------------------------+\n'
}

print_row() {
  local command_name=$1
  local status=$2
  local description=$3

  printf '| %-28s | %-8s | %-64s |\n' "$command_name" "$status" "$description"
}

print_footer() {
  printf '+------------------------------+----------+------------------------------------------------------------------+\n'
}

case "${1:-}" in
  "") ;;
  --all | -a) show_all=true ;;
  --help | -h)
    usage
    exit 0
    ;;
  *)
    printf 'Uso invalido: %s\n\n' "$1" >&2
    usage >&2
    exit 2
    ;;
esac

tools=(
  "cdx|cdx-rs|Navegador de directorios: cd directo, zoxide y TUI fd/fzf/rg."
)

print_banner
print_header

found=0
printed=0
for entry in "${tools[@]}"; do
  command_name=${entry%%|*}
  rest=${entry#*|}
  check_command=${rest%%|*}
  description=${rest#*|}

  if command -v "$check_command" >/dev/null 2>&1; then
    print_row "$command_name" "ok" "$description"
    found=$((found + 1))
    printed=$((printed + 1))
  elif [[ "$show_all" == true ]]; then
    print_row "$command_name" "missing" "$description"
    printed=$((printed + 1))
  fi
done

print_footer

if (( found == 0 )); then
  printf '\nNo encontre ningun comando propio disponible. Usa show-own-x --all para ver la lista completa.\n' >&2
  exit 1
fi

if (( printed == 0 )); then
  exit 1
fi
