# ================================================
# .chezmoiignore - Files to never track
# ================================================

# Credentials and sensitive data
.config/zsh/.zsh_history
dot_config/zsh/private_dot_zsh_history

# Auth tokens managed per-machine (OAuth refreshes constantly)
.local/share/opencode/auth.json

# OneDrive managed separately (KeePassXC database, cloud files, etc.)
OneDrive/**

.local/share/opencode/opencode.db
.local/share/opencode/opencode.db-*
.ssh/id_*
.ssh/known_hosts

# Local app data (not configs)
.local/share/claude/**
.local/share/GitKrakenCLI/**
.local/share/gk/**
.local/share/snip/**
.local/share/wezterm/**

# Generated by linux/setup/setup/*.sh, not managed as dotfiles
dot_local/bin/pypr-*
dot_local/bin/tui-generator
dot_local/bin/tui-generator.sh
dot_local/share/applications/gemini.desktop
dot_local/share/applications/lazygit.desktop
dot_local/share/applications/lazydocker.desktop
dot_local/share/applications/tui-generator.desktop

# Caches and generated files
.config/opencode/node_modules/
.config/opencode/.git/
.config/cagent/
.config/jgit/

# PowerToys requires manual import via GUI
Documents/PowerToys/Backup/*.ptb

# BetterTV/CSGO - destination unknown, leave out for now
# BetterTV/**
# CSGO/**

# LazyVim lockfile - regenerated on install
dot_config/nvim/lazy-lock.json

# Hyde regenerates this on theme switch; we use defaults_from_hyde.conf instead
dot_config/kitty/hyde.conf

# Windows-only configs (AppData, PowerShell, .starship for WT, .datree)
{{- if ne .chezmoi.os "windows" }}
AppData/**
Documents/
.starship/**
.datree/**
.datree
{{- end }}

{{- if ne .chezmoi.os "linux" }}
# Linux-only desktop/app configs
dot_config/Code - OSS/User/settings.json
dot_config/fish/**
dot_config/gh/**
dot_config/keepassxc/**
dot_config/hypr/**
dot_config/kitty/kitty.conf
dot_config/kitty/theme.conf
dot_config/pypr/**
dot_config/rclone/**
dot_config/starship/**
dot_config/waybar/config.jsonc
dot_config/waybar/style.css
dot_config/waybar/includes/**
dot_config/waybar/layouts/**
dot_config/wlogout/**
dot_config/xdg-terminals.list
dot_config/private_user-dirs.dirs
{{- end }}
