{{ if eq .chezmoi.os "windows" -}}
#!/usr/bin/env pwsh
$ErrorActionPreference = "Continue"

$vaultRoot = "$env:USERPROFILE\OneDrive"
$secretFile = "$vaultRoot\secrets\env.toml"

Write-Host ""
Write-Host "--- Secret Vault Check ---" -ForegroundColor Cyan

if (-not (Test-Path $vaultRoot)) {
    Write-Host ""
    Write-Host "===========================================================" -ForegroundColor Yellow
    Write-Host "  Secret vault no encontrado (OneDrive)" -ForegroundColor Yellow
    Write-Host "===========================================================" -ForegroundColor Yellow
    Write-Host ""
    Write-Host "chezmoi necesita que exista:" -ForegroundColor White
    Write-Host "  $secretFile" -ForegroundColor Yellow
    Write-Host ""
    Write-Host "Este archivo contiene secretos que usan los" -ForegroundColor White
    Write-Host "templates de chezmoi:" -ForegroundColor White
    Write-Host "  - [git] email       -> gitconfig" -ForegroundColor Yellow
    Write-Host "  - [ssh] host        -> WezTerm SSH config" -ForegroundColor Yellow
    Write-Host "  - [ssh] username    -> WezTerm SSH config" -ForegroundColor Yellow
    Write-Host "  - [ssh] identity    -> WezTerm SSH config" -ForegroundColor Yellow
    Write-Host "  - firecrawl         -> FIRECRAWL_API_KEY" -ForegroundColor Yellow
    Write-Host ""
    Write-Host "Pasos:" -ForegroundColor White
    Write-Host "  1. Inicia sesion en OneDrive y sincroniza" -ForegroundColor Yellow
    Write-Host "  2. Verifica que secrets\env.toml existe en OneDrive" -ForegroundColor Yellow
    Write-Host "  3. Vuelve a ejecutar: chezmoi apply" -ForegroundColor Yellow
    Write-Host ""
    Write-Host "  Para resetear el estado del script:" -ForegroundColor Cyan
    Write-Host "  chezmoi state delete-bucket --bucket=scriptState" -ForegroundColor Cyan
    Write-Host "===========================================================" -ForegroundColor Yellow
    Write-Host ""
    exit 1
}

if (-not (Test-Path $secretFile)) {
    Write-Host ""
    Write-Host "===========================================================" -ForegroundColor Yellow
    Write-Host "  env.toml no encontrado en el vault" -ForegroundColor Yellow
    Write-Host "===========================================================" -ForegroundColor Yellow
    Write-Host ""
    Write-Host "OneDrive sincronizado, pero falta el archivo:" -ForegroundColor White
    Write-Host "  $secretFile" -ForegroundColor Yellow
    Write-Host ""
    Write-Host "Se espera un archivo TOML con secciones como:" -ForegroundColor White
    Write-Host ""
    Write-Host '  [git]' -ForegroundColor Green
    Write-Host '  email = "tu-email@example.com"' -ForegroundColor Green
    Write-Host '  [ssh]' -ForegroundColor Green
    Write-Host '  host = "192.168.1.1"' -ForegroundColor Green
    Write-Host '  username = "usuario"' -ForegroundColor Green
    Write-Host '  identity = "clave"' -ForegroundColor Green
    Write-Host '  firecrawl = "fc-tu-api-key"' -ForegroundColor Green
    Write-Host ""
    Write-Host "Crea el archivo y vuelve a ejecutar: chezmoi apply" -ForegroundColor Yellow
    Write-Host "  chezmoi state delete-bucket --bucket=scriptState" -ForegroundColor Cyan
    Write-Host "===========================================================" -ForegroundColor Yellow
    exit 1
}

Write-Host "[OK] Secret vault found: $secretFile" -ForegroundColor Green
{{ end -}}
