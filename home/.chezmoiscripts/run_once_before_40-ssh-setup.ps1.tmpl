# run_once_after_40-ssh-setup.ps1
# Configures SSH keys and restores known_hosts from OneDrive
{{- if .ssh_identity }}
$ErrorActionPreference = "Continue"
$sshDir = "$env:USERPROFILE\.ssh"
$oneDriveSshDir = "$env:USERPROFILE\OneDrive\Formateo\.ssh"
$identityFile = Join-Path $sshDir "{{ .ssh_identity }}"

Write-Host "===============================================" -ForegroundColor Cyan
Write-Host "  SSH Setup" -ForegroundColor Cyan
Write-Host "===============================================" -ForegroundColor Cyan

# 1. Ensure .ssh directory exists
if (-not (Test-Path $sshDir)) {
    New-Item -ItemType Directory -Path $sshDir -Force | Out-Null
    Write-Host "[OK] Created .ssh directory" -ForegroundColor Green
}

# 2. Generate SSH key if it doesn't exist
if (-not (Test-Path $identityFile)) {
    Write-Host "[INFO] Generating SSH key: {{ .ssh_identity }}" -ForegroundColor Yellow
    $keyPath = "$sshDir\{{ .ssh_identity }}"
    # Note: ssh-keygen will prompt for passphrase interactively
    ssh-keygen -t ed25519 -f $keyPath -N '""'
    Write-Host "[OK] SSH key generated: $keyPath" -ForegroundColor Green
    Write-Host "" -ForegroundColor Cyan
    Write-Host "IMPORTANT: Copy your public key to the remote server:" -ForegroundColor Cyan
    Write-Host "  Get-Content $keyPath.pub | Set-Clipboard" -ForegroundColor White
    Write-Host "  Then paste it into ~/.ssh/authorized_keys on the remote server" -ForegroundColor White
    Write-Host "" -ForegroundColor Cyan
} else {
    Write-Host "[OK] SSH key already exists: {{ .ssh_identity }}" -ForegroundColor Green
}

# 3. Restore known_hosts from OneDrive
$oneDriveKnownHosts = Join-Path $oneDriveSshDir "known_hosts"
$localKnownHosts = Join-Path $sshDir "known_hosts"

if (Test-Path $oneDriveKnownHosts) {
    Copy-Item -Path $oneDriveKnownHosts -Destination $localKnownHosts -Force
    Write-Host "[OK] Restored known_hosts from OneDrive" -ForegroundColor Green
} else {
    Write-Host "[SKIP] known_hosts not found in OneDrive ($oneDriveSshDir)" -ForegroundColor Yellow
    Write-Host "       It will be created automatically on first SSH connection." -ForegroundColor Yellow
}

# 4. Set correct permissions on Windows
# Remove inheritance and grant only current user read access
$itemsToSecure = @($sshDir, $identityFile, "$identityFile.pub")
if (Test-Path $localKnownHosts) {
    $itemsToSecure += $localKnownHosts
}

foreach ($item in $itemsToSecure) {
    if (Test-Path $item) {
        try {
            icacls $item /inheritance:r /grant:r "$($env:USERNAME):(R)" | Out-Null
        } catch {
            # If icacls fails, at least try to restrict access
            Write-Host "[WARN] Could not set strict permissions on $item" -ForegroundColor Yellow
        }
    }
}
Write-Host "[OK] Permissions configured" -ForegroundColor Green

# 5. Test SSH connection (optional, will prompt to trust host if known_hosts was empty)
{{- if .ssh_host }}
Write-Host ""
Write-Host "[INFO] To test your connection, run:" -ForegroundColor Cyan
Write-Host "  ssh -i ~/.ssh/{{ .ssh_identity }} {{ .ssh_username }}@{{ .ssh_host }}" -ForegroundColor White
Write-Host "  or" -ForegroundColor White
Write-Host "  wezterm connect Jon" -ForegroundColor White
{{- end }}

Write-Host ""
Write-Host "===============================================" -ForegroundColor Cyan
{{- end }}