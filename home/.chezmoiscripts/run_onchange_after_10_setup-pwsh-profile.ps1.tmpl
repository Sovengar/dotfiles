{{ if eq .chezmoi.hostname "NTTD-1H8613110L" -}}
$sourceDir = Join-Path $env:USERPROFILE "Documents\PowerShell"
$profileDir = Split-Path -Parent $PROFILE

if (-not (Test-Path $profileDir)) {
    New-Item -ItemType Directory -Path $profileDir -Force | Out-Null
    Write-Host "Created profile directory: $profileDir"
}

if (Test-Path $sourceDir) {
    Copy-Item -Path "$sourceDir\*" -Destination $profileDir -Recurse -Force
    Write-Host "Synced $sourceDir → $profileDir"
} else {
    Write-Warning "Source directory not found: $sourceDir"
}
{{ end -}}
