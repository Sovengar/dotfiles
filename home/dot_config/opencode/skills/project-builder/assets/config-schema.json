{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://opencode.ai/schemas/project-builder.json",
  "title": "Project Builder Configuration",
  "description": "Configuration file for project-builder skill",
  "type": "object",
  "properties": {
    "build": {
      "type": "object",
      "properties": {
        "system": {
          "type": "string",
          "enum": ["auto", "maven", "gradle", "npm", "pnpm", "yarn"],
          "default": "auto"
        },
        "profile": {
          "type": "string",
          "default": "dev",
          "description": "Spring profile to use (overrides auto-detection)"
        },
        "skipTests": {
          "type": "boolean",
          "default": false
        },
        "jvm": {
          "type": "object",
          "properties": {
            "heap": {
              "type": "string",
              "pattern": "^-Xmx[0-9]+[gmGM]$",
              "examples": ["-Xmx1g", "-Xmx2g", "-Xmx512m"]
            },
            "gc": {
              "type": "string",
              "enum": ["G1GC", "ParallelGC", "ZGC", "ShenandoahGC"],
              "description": "Garbage collector"
            },
            "custom": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Additional JVM arguments"
            }
          }
        },
        "goals": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["clean", "compile", "package", "install", "verify", "test"]
          },
          "default": ["clean", "package"]
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Additional Maven arguments"
        }
      }
    },
    "ci": {
      "type": "object",
      "properties": {
        "java": {
          "type": "string",
          "description": "CI command for Java builds"
        },
        "node": {
          "type": "string",
          "description": "CI command for Node.js builds"
        },
        "mixed": {
          "type": "string",
          "description": "CI command for mixed Java + Node.js projects"
        }
      }
    },
    "detection": {
      "type": "object",
      "properties": {
        "excludeDirs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": ["node_modules", "target", "dist", ".git"],
          "description": "Directories to exclude from detection"
        },
        "profilePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": ["application-*.yml", "application-*.yaml", "application-*.properties"],
          "description": "Glob patterns for Spring profile detection"
        }
      }
    }
  },
  "examples": [
    {
      "build": {
        "system": "auto",
        "profile": "dev",
        "skipTests": false,
        "jvm": {
          "heap": "-Xmx2g",
          "gc": "G1GC"
        },
        "goals": ["clean", "package"]
      },
      "ci": {
        "java": "mvn clean package -Pprod -DskipTests -Xmx4g"
      }
    },
    {
      "build": {
        "system": "npm",
        "skipTests": false
      },
      "ci": {
        "node": "npm ci --omit=dev"
      }
    }
  ]
}