#!/usr/bin/env python3
import glob
import json
import os
import sys
import urllib.error
import urllib.request

BRIDGER_DIRS = [
    "/tmp/opencode-prompt-bridger",
    "/tmp/opencode-prompt-bridge",
]


def read_text() -> str:
    if len(sys.argv) > 1:
        return " ".join(sys.argv[1:])
    return sys.stdin.read()


def bridge_url() -> str | None:
    if os.environ.get("OPENCODE_PROMPT_BRIDGER_URL"):
        return os.environ["OPENCODE_PROMPT_BRIDGER_URL"].rstrip("/")

    if os.environ.get("OPENCODE_PROMPT_BRIDGE_URL"):
        return os.environ["OPENCODE_PROMPT_BRIDGE_URL"].rstrip("/")

    pid = os.environ.get("OPENCODE_PID")
    if pid:
        for bridge_dir in BRIDGER_DIRS:
            path = os.path.join(bridge_dir, f"{pid}.json")
            url = read_bridge_url(path)
            if url:
                return url

    entries = []
    for bridge_dir in BRIDGER_DIRS:
        entries.extend(glob.glob(os.path.join(bridge_dir, "*.json")))

    entries = sorted(entries, key=os.path.getmtime, reverse=True)
    if len(entries) == 1:
        return read_bridge_url(entries[0])

    return None


def read_bridge_url(path: str) -> str | None:
    try:
        with open(path, "r", encoding="utf-8") as handle:
            data = json.load(handle)
        url = data.get("url")
        return url.rstrip("/") if isinstance(url, str) else None
    except OSError:
        return None
    except json.JSONDecodeError:
        return None


def main() -> int:
    text = read_text()
    if not text.strip():
        print("No text provided", file=sys.stderr)
        return 2

    url = bridge_url()
    if not url:
        print("No OpenCode prompt bridger found", file=sys.stderr)
        return 2

    request = urllib.request.Request(
        f"{url}/append",
        data=json.dumps({"text": text}).encode("utf-8"),
        headers={"Content-Type": "application/json"},
        method="POST",
    )

    try:
        with urllib.request.urlopen(request, timeout=2) as response:
            if response.status == 200:
                return 0
            print(f"Bridge returned HTTP {response.status}", file=sys.stderr)
            return 1
    except urllib.error.HTTPError as error:
        print(f"Bridge returned HTTP {error.code}: {error.read().decode('utf-8', 'ignore')}", file=sys.stderr)
        return 1
    except OSError as error:
        print(f"Bridge request failed: {error}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
