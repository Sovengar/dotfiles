{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "C:\\Users\\buble\\.config\\opencode\\plugins\\shell-strategy\\shell_strategy.md"
  ],
  "plugin": [
    "@tarquinen/opencode-smart-title",
    //Es util que se abra un plan que pueda añadirle comentarios pero se hace pesado "@plannotator/opencode@latest", Opcion 2, no probada "open-plan-annotator@latest"
    "cc-safety-net",
    "@simonwjackson/opencode-direnv",
    "opencode-pty",
    "opencode-firecrawl",

    // CONTEXT OPTIMIZER
    // DISABLED: replaced by opencode-selective-snip
    // "opencode-snip@latest",
    "opencode-selective-snip",
    //Pesao de mierda me interrumpe y lo vuelve loco "@tarquinen/opencode-dcp@latest",

    // AGENTS
    "@gotgenes/opencode-agent-identity",
    "@zenobius/opencode-background",
    //NO TMUX https://github.com/mailshieldai/opencode-canvas,
    //NO TMUX https://github.com/AnganSamadder/opentmux

    // GUARDRAILS
    "opencode-vibeguard",
    "envsitter-guard@latest",
    "@nick-vi/opencode-type-inject",

    // TELEMETRY
    "@slkiser/opencode-quota",
    "@ramtinj95/opencode-tokenscope@latest",
    //OVERKILL "@devtheops/opencode-plugin-otel"

    // NOTIFICATIONS
    //Not working "@pantheon-ai/opencode-warcraft-notifications"
    //Fallback https://github.com/kdcokenny/opencode-notify
    //Fallback https://github.com/renjfk/opencode-voice
    "opencode-smart-voice-notify@latest"
  ],
  "mcp": {
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "engram": {
      "command": [
        "C:\\Users\\buble\\AppData\\Local\\engram\\bin\\engram.exe",
        "mcp",
        "--tools=agent"
      ],
      "type": "local"
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": true
    },
    // "notion": {
    //   "enabled": false,
    //   "type": "remote",
    //   "url": "https://mcp.notion.com/mcp"
    // },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": false
    },
    // "excalidraw": {
    //   "enabled": false,
    //   "command": "node",
    //   "args": ["/path/to/excalidraw-mcp-app/dist/index.js", "--stdio"]
    // }
  },
  "permission": {
    "*": "allow",
    "external_directory": {
      "~/.local/**": "allow",
      "~/AppData/**": "allow",
      "~/.config/**": "allow",
      "~/.npm/**": "allow",
      "~/.cargo/**": "allow",
      "~/dev/**": "allow"
    },
    "bash": {
      "*": "allow",
      "git commit *": "ask",
      "git push": "ask",
      "git push *": "ask",
      "git push --force *": "ask",
      "git rebase *": "ask",
      "git reset --hard *": "ask"
    },
    "read": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/credentials.json": "deny",
      "**/secrets/**": "deny",
      "*.env": "deny",
      "*.env.*": "deny"
    }
  },
  "experimental": {
    "quotaToast": {
      "enableToast": false,
      "showSessionTokens": false, //Show input and output tokens (We have the Context from Opencode, enough)
      "enabledProviders": ["openai", "opencode-go"], // auto, "copilot", 
      "formatStyle": "allWindows", // Show all quota windows instead of the default single-window layout
      "percentDisplayMode": "used"
    }
  }
}
