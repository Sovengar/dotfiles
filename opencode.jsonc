{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "C:\\Users\\buble\\.config\\opencode\\plugins\\shell-strategy\\shell_strategy.md"
  ],
  "plugin": [
    "@tarquinen/opencode-smart-title",
    "@gotgenes/opencode-agent-identity",
    "@tarquinen/opencode-dcp@latest",
    //Es util que se abra un plan que pueda añadirle comentarios pero se hace pesado "@plannotator/opencode@latest",
    "cc-safety-net",
    "@simonwjackson/opencode-direnv",
    "envsitter-guard@latest",
    "opencode-snip@latest",
    "opencode-pty",
    "@nick-vi/opencode-type-inject",
    "opencode-firecrawl",
    "opencode-vibeguard"
  ],
  "mcp": {
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "engram": {
      "command": [
        "C:\\Users\\buble\\AppData\\Local\\engram\\bin\\engram.exe",
        "mcp",
        "--tools=agent"
      ],
      "type": "local"
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "git commit *": "ask",
      "git push": "ask",
      "git push *": "ask",
      "git push --force *": "ask",
      "git rebase *": "ask",
      "git reset --hard *": "ask"
    },
    "read": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/credentials.json": "deny",
      "**/secrets/**": "deny",
      "*.env": "deny",
      "*.env.*": "deny"
    }
  }
}